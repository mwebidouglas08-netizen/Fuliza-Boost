# Copy this file to .env and fill in your values
# Never commit .env to git

NODE_ENV=development

# Admin credentials (change before going live!)
ADMIN_USER=admin
ADMIN_PASS=admin123

# Session secret - use a long random string in production
SESSION_SECRET=change-this-to-a-long-random-string-in-production

# Lipana Technologies M-Pesa API
LIPANA_API_KEY=sk_live_your_api_key_here

# Your live domain (needed for M-Pesa callbacks)
# Example: https://fulizaboost-production.up.railway.app
BASE_URL=http://localhost:3000
